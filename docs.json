            "pages": [
              "api/users/register",
              "api/users/login",
              "api/users/me",
              "api/users/get-by-id",
              "api/users/change-password",
              "api/users/delete",
              "api/users/verify-token"
            ]
          },
          {
            "group": "Media",
            "pages": [
              "api/media/upload-image",
              "api/media/get-image",
              "api/media/delete-image",
              "api/media/upload-video",
