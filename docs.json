{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Periodico Backend",
  "theme": "sequoia",
  "colors": {
    "primary": "#1a1a2e",
    "light": "#2563eb",
    "dark": "#0f172a"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/nic0lasGP/periodicoBackend"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/nic0lasGP/periodicoBackend"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart", "authentication"]
          },
          {
            "group": "Core Concepts",
