            ]
          },
          {
            "group": "Admin",
            "pages": [
              "api/admin/get-all-users",
              "api/admin/create-post",
              "api/admin/update-post",
              "api/admin/delete-post",
              "api/admin/toggle-publish",
              "api/admin/create-section",
              "api/admin/delete-section",
              "api/admin/delete-user",
              "api/admin/pdf-to-html"
            ]
