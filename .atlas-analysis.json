{
  "projectType": "api-service",
  "projectName": "Periodico Backend",
  "projectDescription": "A FastAPI-based REST API backend for a digital newspaper platform, providing endpoints for managing news posts, sections, users, media (images and videos), and admin operations.",
  "theme": "sequoia",
  "primaryColor": "#1a1a2e",
  "lightColor": "#2563eb",
