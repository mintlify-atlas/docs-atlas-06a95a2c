  "keyFeatures": [
    "News post management with zlib-compressed HTML body content",
    "Section-based content organization for categorizing news articles",
    "JWT-based authentication with role-based access control (admin vs. regular users)",
    "Media management for images (with compression) and videos (with streaming)",
    "PDF to HTML conversion utility for admin content creation",
    "MySQL database backend with PyMySQL",
    "CORS support for cross-origin frontend integrations",
    "BCrypt password hashing for secure credential storage"
  ],
  "publicApiSurface": [
    "GET /posts/get-all",
    "GET /posts/get-by-id?id={id}",
    "GET /posts/get-all-by-section?section={name}",
    "GET /posts/{section}/{slug}",
    "GET /sections/get-all",
    "GET /sections/get-by-id?id={id}",
    "GET /sections/get-by-name?name={name}",
    "POST /users/register",
    "POST /users/login",
    "GET /users/me",
    "GET /users/get-by-id?id={id}",
    "GET /users/get-by-gmail?gmail={gmail}",
    "PATCH /users/change-password",
    "DELETE /users/delete-me",
    "GET /user/verify-token",
    "POST /media/upload/image",
    "GET /media/image/{media_id}",
    "DELETE /media/image/delete-by-id",
    "POST /upload/video",
    "GET /media/video/{video_id}",
    "DELETE /media/video/delete-by-id",
    "GET /admin/users",
    "POST /admin/create-post",
    "PATCH /admin/update-post",
    "DELETE /admin/delete-post",
    "PATCH /admin/alternate-publish-state-post",
    "POST /admin/create-section",
    "DELETE /admin/delete-section",
    "DELETE /admin/delete-user-by-gmail",
    "DELETE /admin/delete-user-by-id",
    "POST /convert/pdf-to-html"
  ]
